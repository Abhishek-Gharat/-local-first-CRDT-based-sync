# Admin/migration connection (superuser — bypasses RLS). Used only by
# drizzle-kit to run migrations. Never point the running app at this.
DATABASE_URL="postgresql://docsync:docsync@localhost:5432/docsync"

# Runtime app connection — a non-superuser role actually subject to RLS.
# Created locally by docker/init-app-role.sh; on a hosted provider, create
# the equivalent restricted role yourself and grant it per
# src/db/migrations/0001_rls_policies.sql.
APP_DATABASE_URL="postgresql://app_user:app_user@localhost:5432/docsync"

# NextAuth v5 — used to encrypt/sign session JWTs. Generate with:
# `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET="replace-with-a-real-32+-byte-random-secret"

# Shared secret for signing the short-lived sync-server handshake tokens
# minted at GET /api/documents/[id]/sync-token — must match sync-server's
# SYNC_TOKEN_SECRET exactly (see apps/sync-server/.env.example). Generate the
# same way as AUTH_SECRET; don't reuse the same value for both.
SYNC_TOKEN_SECRET="replace-with-a-different-real-32+-byte-random-secret"

# Browser-facing WS URL of apps/sync-server (this is exposed to the client —
# do not put a secret here). Matches apps/sync-server's SYNC_SERVER_PORT.
NEXT_PUBLIC_SYNC_SERVER_URL="ws://localhost:1234"

# --- AI change summaries (optional) ---------------------------------------
# The version-history "Summarize changes" feature is provider-swappable and
# degrades gracefully: with NO key set it returns a deterministic word-count
# diff instead of a model summary, so the app runs fine without any of these.
#
# Pick a provider explicitly, or leave AI_PROVIDER unset and just supply one
# key below — the provider is inferred from whichever key is present.
# AI_PROVIDER="anthropic"   # or "openai" / "groq"
# AI_MODEL="claude-haiku-4-5-20251001"   # optional model-id override
#
# Only ONE of these is needed, matching the provider above:
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# GROQ_API_KEY="gsk_..."   # free tier at console.groq.com

