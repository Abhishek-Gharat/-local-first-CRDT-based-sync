SYNC_SERVER_PORT=1234

# Must match apps/web's SYNC_TOKEN_SECRET exactly — sync-server verifies the
# handshake tokens apps/web mints at GET /api/documents/[id]/sync-token.
# Verification lands in M7; the value has to match starting now so both
# sides are ready when it does.
SYNC_TOKEN_SECRET="replace-with-a-different-real-32+-byte-random-secret"
